#!/usr/bin/env bash

set -e

# Bookworm extracts the official AppImage during the image build. Trixie and
# Arch preserve their packaged native binaries before applying this overlay.
if [[ -x /opt/sunshine-native/sunshine ]]; then
    exec /opt/sunshine-native/sunshine "$@"
fi

if [[ -x /opt/sunshine/AppRun ]]; then
    exec /opt/sunshine/AppRun "$@"
fi

echo "FATAL: No Sunshine executable was installed" >&2
exit 127
